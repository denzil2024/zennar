# Postgres connection (Railway injects DATABASE_URL automatically when the
# Postgres plugin is attached to this service).
DATABASE_URL=postgresql://user:password@host:5432/zennara

# Comma-separated list of allowed frontend origins (the marketing site).
CORS_ORIGIN=http://localhost:5178,https://zennara-production.up.railway.app

# Port the API listens on (Railway sets PORT automatically).
PORT=8080

# Secret used to hash login codes (set any long random string).
CODE_SECRET=

# Shared secret for the admin endpoints (creating clients) until the admin UI lands.
ADMIN_TOKEN=

# Public portal login URL included in the WhatsApp code message.
PORTAL_URL=https://zennarafp.com/portal

# ZENNARA WhatsApp /send service (step 2). Leave blank to fall back to devCode.
WHATSAPP_SEND_URL=
WHATSAPP_SEND_TOKEN=
