# Port the service listens on (Railway sets PORT automatically).
PORT=3000

# Shared secret the portal API must send as `Authorization: Bearer <token>`
# to use /send. Must match the API's WHATSAPP_SEND_TOKEN. Use a long random string.
SEND_TOKEN=

# Where the WhatsApp session is stored. Point this at a Railway VOLUME mount
# (e.g. /data/auth_info) so the number stays linked across redeploys.
AUTH_DIR=/data/auth_info
