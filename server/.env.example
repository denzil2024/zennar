# Postgres connection (Railway injects DATABASE_URL automatically when the
# Postgres plugin is attached to this service).
DATABASE_URL=postgresql://user:password@host:5432/zennara

# Comma-separated list of allowed frontend origins (the marketing site).
CORS_ORIGIN=http://localhost:5178,https://zennara-production.up.railway.app

# Port the API listens on (Railway sets PORT automatically).
PORT=8080

# Shared secret the API uses to call ZENNARA's WhatsApp /send service (step 2).
WHATSAPP_SEND_URL=
WHATSAPP_SEND_TOKEN=
